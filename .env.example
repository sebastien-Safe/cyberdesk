# Supabase — projet CyberDesk (jamais celui de safecrm)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx
PROJECT_REF=xxxx

# IA — assistant cybersécurité (Edge Function cyber-ia-assistant)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Purge RGPD automatique (Edge Function purge-cybervictim-data)
# Secret partagé entre le job pg_cron et l'Edge Function — génère une
# valeur aléatoire longue (ex: openssl rand -hex 32) et configure-la
# aussi côté Supabase Vault pour le job cron.
PURGE_SECRET=xxxx

# Envoi d'email — résultats du quiz public (Edge Function send-audit-email)
# Fournisseur : Resend (https://resend.com/api-keys). Adapter le fournisseur
# dans le code de la fonction si un autre service est préféré.
RESEND_API_KEY=re_xxxx
AUDIT_EMAIL_FROM="CyberDesk <contact@votre-domaine.fr>"

# Ne jamais committer ce fichier une fois rempli — seul .env.example
# (avec des valeurs factices) doit être versionné.
